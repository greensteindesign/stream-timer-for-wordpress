msgid "Stream Timer"
msgstr "Stream Timer"

msgid "Schedule-based Twitch or YouTube stream embed. Plan multiple time windows in advance. Configurable in the backend, insert via shortcode [stream_timer]. Performance optimized: assets load only when the shortcode is present and a window is active."
msgstr "Inserción de stream de Twitch o YouTube programada. Planifica varias ventanas de tiempo con antelación. Configurable en el backend, insertable mediante el shortcode [stream_timer]. Optimizado para el rendimiento: los recursos solo se cargan cuando el shortcode está presente y una ventana está activa."

msgid "Insufficient permissions."
msgstr "Permisos insuficientes."

msgid "Configuration for the scheduled stream embed. Insert via shortcode:"
msgstr "Configuración para la inserción programada del stream. Inserta mediante el shortcode:"

msgid "Preview (always show):"
msgstr "Vista previa (mostrar siempre):"

msgid "Platform & Channel"
msgstr "Plataforma y canal"

msgid "Platform"
msgstr "Plataforma"

msgid "Channel / Video ID"
msgstr "Canal / ID de vídeo"

msgid "Twitch: channel name (4–25 characters). YouTube Live: Channel ID (UC…). YouTube Video: 11-character video ID."
msgstr "Twitch: nombre del canal (4–25 caracteres). YouTube Live: ID del canal (UC…). YouTube Vídeo: ID del vídeo de 11 caracteres."

msgid "YouTube mode"
msgstr "Modo YouTube"

msgid "Live (Channel ID)"
msgstr "En directo (ID del canal)"

msgid "Video (Video ID)"
msgstr "Vídeo (ID del vídeo)"

msgid "Only relevant when Platform = YouTube."
msgstr "Solo relevante cuando Plataforma = YouTube."

msgid "Timezone"
msgstr "Zona horaria"

msgid "Time Windows (Schedule)"
msgstr "Ventanas de tiempo (programación)"

msgid "General"
msgstr "General"

msgid "Twitch name, YouTube UC… ID, or 11-char video ID"
msgstr "Nombre Twitch, ID UC… de YouTube o ID de vídeo de 11 caracteres"

#, php-format
msgid "Plan multiple windows in advance (max. %d). Each window has its own source (platform + channel). The embed is shown as soon as any window is active."
msgstr "Planifica varias ventanas con antelación (máx. %d). Cada ventana tiene su propia fuente (plataforma + canal). La inserción se muestra cuando cualquier ventana esté activa."

#, php-format
msgid "Active window: %1$s (%2$s)"
msgstr "Ventana activa: %1$s (%2$s)"

#, php-format
msgid "Plan multiple windows in advance (max. %d). The embed is shown as soon as any window is active."
msgstr "Planifica varias ventanas con antelación (máx. %d). La inserción se muestra cuando cualquier ventana esté activa."

msgid "Label (optional)"
msgstr "Etiqueta (opcional)"

msgid "Start"
msgstr "Inicio"

msgid "End"
msgstr "Fin"

msgid "Daily"
msgstr "Diario"

msgid "Status"
msgstr "Estado"

msgid "Add time window"
msgstr "Añadir ventana"

msgid "Maximum number of time windows reached."
msgstr "Número máximo de ventanas alcanzado."

msgid "Display"
msgstr "Apariencia"

msgid "Height (px)"
msgstr "Altura (px)"

msgid "Element to hide (CSS selector)"
msgstr "Elemento a ocultar (selector CSS)"

msgid "Optional. Allowed: classes, IDs, tags, combinators (>+~,), pseudo-classes (:hover etc.). No attribute values, no quotes."
msgstr "Opcional. Permitido: clases, IDs, etiquetas, combinadores (>+~,), pseudoclases (:hover etc.). Sin valores de atributo, sin comillas."

msgid "Wrapper ID"
msgstr "ID del contenedor"

msgid "Current Status"
msgstr "Estado actual"

msgid "A stream window is currently active."
msgstr "Hay una ventana de stream activa."

msgid "(no label)"
msgstr "(sin etiqueta)"

#, php-format
msgid "Active window: %s"
msgstr "Ventana activa: %s"

msgid "No stream window is currently active."
msgstr "Ninguna ventana de stream está activa."

#, php-format
msgid "Current server time (%2$s): %1$s"
msgstr "Hora actual del servidor (%2$s): %1$s"

#, php-format
msgid "Next window: %1$s — %2$s to %3$s"
msgstr "Próxima ventana: %1$s — %2$s a %3$s"

msgid "e.g. Wednesday Stream"
msgstr "p. ej. Stream del miércoles"

msgid "repeat"
msgstr "repetir"

msgid "active"
msgstr "activa"

msgid "Remove"
msgstr "Eliminar"

#, php-format
msgid "Made with %1$s by %2$s"
msgstr "Hecho con %1$s por %2$s"

msgid "Settings saved."
msgstr "Ajustes guardados."
