msgid "Stream Timer"
msgstr "Stream Timer"

msgid "Schedule-based Twitch or YouTube stream embed. Plan multiple time windows in advance. Configurable in the backend, insert via shortcode [stream_timer]. Performance optimized: assets load only when the shortcode is present and a window is active."
msgstr "Zeitgesteuerter Twitch- oder YouTube-Stream-Embed. Mehrere Zeitfenster im Voraus planbar. Konfigurierbar im Backend, einbindbar per Shortcode [stream_timer]. Performance-optimiert: Assets werden nur geladen, wenn der Shortcode auf der Seite vorhanden und ein Zeitfenster aktiv ist."

msgid "Insufficient permissions."
msgstr "Unzureichende Berechtigung."

msgid "Configuration for the scheduled stream embed. Insert via shortcode:"
msgstr "Konfiguration für den zeitgesteuerten Stream-Embed. Einbindung per Shortcode:"

msgid "Preview (always show):"
msgstr "Vorschau (immer anzeigen):"

msgid "Platform & Channel"
msgstr "Plattform & Channel"

msgid "Platform"
msgstr "Plattform"

msgid "Channel / Video ID"
msgstr "Channel / Video-ID"

msgid "Twitch: channel name (4–25 characters). YouTube Live: Channel ID (UC…). YouTube Video: 11-character video ID."
msgstr "Twitch: Channel-Name (4–25 Zeichen). YouTube Live: Channel-ID (UC…). YouTube Video: 11-stellige Video-ID."

msgid "YouTube mode"
msgstr "YouTube-Modus"

msgid "Live (Channel ID)"
msgstr "Live (Channel-ID)"

msgid "Video (Video ID)"
msgstr "Video (Video-ID)"

msgid "Only relevant when Platform = YouTube."
msgstr "Nur relevant, wenn Plattform = YouTube."

msgid "Timezone"
msgstr "Zeitzone"

msgid "Time Windows (Schedule)"
msgstr "Zeitfenster (Planung)"

msgid "General"
msgstr "Allgemein"

msgid "Twitch name, YouTube UC… ID, or 11-char video ID"
msgstr "Twitch-Name, YouTube UC…-ID oder 11-stellige Video-ID"

#, php-format
msgid "Plan multiple windows in advance (max. %d). Each window has its own source (platform + channel). The embed is shown as soon as any window is active."
msgstr "Mehrere Fenster im Voraus planbar (max. %d). Jedes Fenster hat eine eigene Quelle (Plattform + Channel). Sobald irgendein Fenster aktiv ist, wird der Embed angezeigt."

#, php-format
msgid "Active window: %1$s (%2$s)"
msgstr "Aktives Fenster: %1$s (%2$s)"

#, php-format
msgid "Plan multiple windows in advance (max. %d). The embed is shown as soon as any window is active."
msgstr "Mehrere Fenster im Voraus planbar (max. %d). Sobald irgendein Fenster aktiv ist, wird der Embed angezeigt."

msgid "Label (optional)"
msgstr "Bezeichnung (optional)"

msgid "Start"
msgstr "Start"

msgid "End"
msgstr "Ende"

msgid "Daily"
msgstr "Täglich"

msgid "Status"
msgstr "Status"

msgid "Add time window"
msgstr "Zeitfenster hinzufügen"

msgid "Maximum number of time windows reached."
msgstr "Maximale Anzahl Zeitfenster erreicht."

msgid "Display"
msgstr "Darstellung"

msgid "Height (px)"
msgstr "Höhe (px)"

msgid "Element to hide (CSS selector)"
msgstr "Auszublendendes Element (CSS-Selektor)"

msgid "Optional. Allowed: classes, IDs, tags, combinators (>+~,), pseudo-classes (:hover etc.). No attribute values, no quotes."
msgstr "Optional. Erlaubt: Klassen, IDs, Tags, Kombinatoren (>+~,), Pseudoklassen (:hover etc.). Keine Attribut-Werte, keine Quotes."

msgid "Wrapper ID"
msgstr "Wrapper-ID"

msgid "Current Status"
msgstr "Aktueller Status"

msgid "A stream window is currently active."
msgstr "Stream-Fenster ist gerade aktiv."

msgid "(no label)"
msgstr "(ohne Bezeichnung)"

#, php-format
msgid "Active window: %s"
msgstr "Aktives Fenster: %s"

msgid "No stream window is currently active."
msgstr "Stream-Fenster ist gerade nicht aktiv."

#, php-format
msgid "Current server time (%2$s): %1$s"
msgstr "Aktuelle Serverzeit (%2$s): %1$s"

#, php-format
msgid "Next window: %1$s — %2$s to %3$s"
msgstr "Nächstes Fenster: %1$s — %2$s bis %3$s"

msgid "e.g. Wednesday Stream"
msgstr "z. B. Mittwochs-Stream"

msgid "repeat"
msgstr "wiederholen"

msgid "active"
msgstr "aktiv"

msgid "Remove"
msgstr "Entfernen"

#, php-format
msgid "Made with %1$s by %2$s"
msgstr "Erstellt mit %1$s von %2$s"

msgid "Settings saved."
msgstr "Einstellungen gespeichert."
